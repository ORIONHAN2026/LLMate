{
  "vendor": {
    "id": "local",
    "name": "本地工具",
    "description": "无需授权的本地 MCP 服务，直接通过命令行启动",
    "icon": "desktopcomputer",
    "color": "#607D8B",
    "requiresAuth": false
  },
  "items": [
    {
      "name": "filesystem",
      "description": "文件系统访问服务，读取、写入和管理本地文件，支持目录浏览",
      "category": "文件系统",
      "content": "{\"command\":\"npx\",\"args\":[\"-y\",\"@modelcontextprotocol/server-filesystem\",\"/Users\"]}"
    },
    {
      "name": "sqlite",
      "description": "SQLite 数据库连接，执行查询和数据操作",
      "category": "数据库",
      "content": "{\"command\":\"npx\",\"args\":[\"-y\",\"@modelcontextprotocol/server-sqlite\",\"./database.sqlite\"]}"
    },
    {
      "name": "postgres",
      "description": "PostgreSQL 连接，支持复杂 SQL 查询和数据管理",
      "category": "数据库",
      "content": "{\"command\":\"npx\",\"args\":[\"-y\",\"@modelcontextprotocol/server-postgres\",\"--connection-string\",\"postgresql://localhost/db\"]}"
    },
    {
      "name": "redis",
      "description": "Redis 缓存服务，键值操作和数据管理",
      "category": "数据库",
      "content": "{\"command\":\"npx\",\"args\":[\"-y\",\"@modelcontextprotocol/server-redis\",\"--uri\",\"redis://localhost:6379\"]}"
    },
    {
