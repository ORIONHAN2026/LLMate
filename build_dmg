#!/bin/bash
set -e

echo "============================================"
echo "  LLMWork macOS DMG 打包脚本"
echo "============================================"
echo ""

# 清理旧构建
echo "[1/3] 清理旧构建..."
rm -rf build/macos/Build/Products/Release/LLMWork.app
rm -f LLMWork.dmg

# 编译 Release 版本
echo "[2/3] 编译 macOS Release 版本..."
flutter build macos --release

# 打包 DMG
echo "[3/3] 打包 DMG..."
create-dmg \
  --volname "LLMWork" \
  --window-pos 200 120 \
  --window-size 800 400 \
  --icon-size 100 \
  --app-drop-link 600 185 \
  "LLMWork.dmg" \
  "build/macos/Build/Products/Release/LLMWork.app"

echo ""
echo "============================================"
echo "  打包完成！输出: LLMWork.dmg"
echo "============================================"
 
 